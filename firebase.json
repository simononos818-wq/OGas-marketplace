{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/payment/verify/**",
        "run": { "serviceId": "paymentverify", "region": "us-central1" }
      },
      {
        "source": "/api/payment/webhook/**",
        "run": { "serviceId": "paymentwebhook", "region": "us-central1" }
      },
      {
        "source": "/api/paystack/resolve-bank/**",
        "run": { "serviceId": "resolvebank", "region": "us-central1" }
      },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
