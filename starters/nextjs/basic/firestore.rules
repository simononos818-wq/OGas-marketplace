rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sellers collection
    match /sellers/{sellerId} {
      // Anyone can read active sellers
      allow read: if resource.data.isActive == true;
      
      // Anyone can create a seller application
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'businessName', 'city', 'pricePerKg', 'isActive', 'isVerified'])
        && request.resource.data.isActive == true
        && request.resource.data.isVerified == false;
      
      // Only the seller or admin can update
      allow update: if request.auth != null 
        || request.resource.data.phone == resource.data.phone;
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Buyers can read their own orders
      allow read: if request.auth != null 
        || resource.data.buyerPhone == request.resource.data.buyerPhone
        || resource.data.sellerPhone == request.resource.data.sellerPhone;
      
      // Anyone can create an order (anonymous buyers)
      allow create: if request.resource.data.keys().hasAll(['buyerId', 'buyerName', 'buyerPhone', 'sellerId', 'items', 'total', 'status'])
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'pending';
      
      // Seller can update status, buyer can add review
      allow update: if request.auth != null
        || (resource.data.sellerPhone == request.resource.data.sellerPhone && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
        || (resource.data.buyerPhone == request.resource.data.buyerPhone && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'review', 'updatedAt']));
    }
    
    // Users collection (for future auth)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
