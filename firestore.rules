rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /sellers/{sellerId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(sellerId) || isAdmin();
    }
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
    }
    match /escrows/{escrowId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isAuth() && resource.data.sellerId == request.auth.uid);
      allow write: if false;
    }
    match /admins/{adminId} {
      allow read: if isAuth() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
