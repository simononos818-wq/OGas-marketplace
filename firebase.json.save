{
  "hosting": {
    "source": "starters/nextjs/firebase-ecommerce"
  }
}
{
  "hosting": {
    "public": "starters/nextjs/basic/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
